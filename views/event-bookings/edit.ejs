<%
  // Pre-fill: konversi Date object dari DB ke format yang dibutuhkan input HTML
  const eventDateStr = new Date(booking.eventDate).toISOString().split('T')[0];
  const startH = new Date(booking.startTime).getUTCHours().toString().padStart(2,'0');
  const startM = new Date(booking.startTime).getUTCMinutes().toString().padStart(2,'0');
  const startTimeStr = startH + ':' + startM;
  const endH = new Date(booking.endTime).getUTCHours().toString().padStart(2,'0');
  const endM = new Date(booking.endTime).getUTCMinutes().toString().padStart(2,'0');
  const endTimeStr = endH + ':' + endM;
%>

<!-- Breadcrumb -->
<nav class="flex items-center gap-1.5 text-xs text-gray-400 mb-5">
  <a href="/event-bookings" class="hover:text-blue-500">Event Bookings</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <a href="/event-bookings/<%= booking.id %>" class="hover:text-blue-500"><%= booking.eventName %></a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-700 font-medium">Edit</span>
</nav>

<div class="max-w-2xl">
  <div class="bg-white rounded-card border border-slate-100 shadow-card p-6">
    <div class="mb-6">
      <h1 class="text-lg font-bold text-gray-900">Edit Booking</h1>
      <p class="text-xs text-gray-400 mt-0.5">Update booking information below.</p>
    </div>

    <form action="/event-bookings/<%= booking.id %>/update" method="POST" class="space-y-4">

      <!-- Venue -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Venue <span class="text-red-400">*</span></label>
        <select name="venue_id" required
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-slate-50 transition-colors">
          <% venues.forEach(venue => { %>
            <option value="<%= venue.id %>"
              <%= booking.venueId === venue.id ? 'selected' : '' %>
              <%= venue.status !== 'available' && booking.venueId !== venue.id ? 'disabled' : '' %>>
              <%= venue.name %> (<%= venue.status === 'available' ? 'Available' : venue.status %>)
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Event Name -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Event Name <span class="text-red-400">*</span></label>
        <input type="text" name="event_name" required maxlength="150" value="<%= booking.eventName %>"
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-slate-50 transition-colors" />
      </div>

      <!-- Organizer -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Organizer Name <span class="text-red-400">*</span></label>
        <input type="text" name="organizer_name" required maxlength="100" value="<%= booking.organizerName %>"
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-slate-50 transition-colors" />
      </div>

      <!-- Date & Attendees -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Event Date <span class="text-red-400">*</span></label>
          <input type="date" name="event_date" required value="<%= eventDateStr %>"
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-slate-50 transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Attendees <span class="text-gray-400 text-xs font-normal">(optional)</span></label>
          <input type="number" name="attendees" min="1" value="<%= booking.attendees ?? '' %>"
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-slate-50 transition-colors" />
        </div>
      </div>

      <!-- Time -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Start Time <span class="text-red-400">*</span></label>
          <input type="time" name="start_time" required value="<%= startTimeStr %>"
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-slate-50 transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">End Time <span class="text-red-400">*</span></label>
          <input type="time" name="end_time" required value="<%= endTimeStr %>"
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-slate-50 transition-colors" />
        </div>
      </div>

      <!-- Status -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Booking Status</label>
          <select name="booking_status"
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-slate-50 transition-colors">
            <option value="pending" <%= booking.bookingStatus === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="confirmed" <%= booking.bookingStatus === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
            <option value="cancelled" <%= booking.bookingStatus === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Payment Status</label>
          <select name="payment_status"
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-slate-50 transition-colors">
            <option value="unpaid" <%= booking.paymentStatus === 'unpaid' ? 'selected' : '' %>>Unpaid</option>
            <option value="paid" <%= booking.paymentStatus === 'paid' ? 'selected' : '' %>>Paid</option>
            <option value="refunded" <%= booking.paymentStatus === 'refunded' ? 'selected' : '' %>>Refunded</option>
          </select>
        </div>
      </div>

      <!-- Notes -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Notes <span class="text-gray-400 text-xs font-normal">(optional)</span></label>
        <textarea name="notes" rows="3"
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 bg-slate-50 resize-none transition-colors"><%= booking.notes ?? '' %></textarea>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit"
          class="px-5 py-2.5 bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold rounded-xl transition-colors shadow-sm">
          Save Changes
        </button>
        <a href="/event-bookings/<%= booking.id %>"
          class="px-5 py-2.5 bg-slate-50 hover:bg-slate-100 text-gray-600 text-sm font-medium rounded-xl transition-colors border border-slate-200">
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>