<% function fmtTime(dt) { const d=new Date(dt); return d.getUTCHours().toString().padStart(2,'0') + ':' +
  d.getUTCMinutes().toString().padStart(2,'0'); } function fmtDate(dt) { return new Date(dt).toLocaleDateString('id-ID',
  { weekday: 'long' , day: '2-digit' , month: 'long' , year: 'numeric' , timeZone: 'UTC' }); } function
  fmtDateRange(startDt, endDt) { const start=fmtDate(startDt); const end=fmtDate(endDt); return start===end ? start :
  start + ' - ' + end; } %>

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-1.5 text-xs text-gray-400 mb-5">
    <a href="/event-bookings" class="hover:text-blue-500">Event Bookings</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <span class="text-gray-700 font-medium">
      <%= booking.eventName %>
    </span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

    <!-- Main: Booking Detail -->
    <div class="lg:col-span-2 space-y-5">
      <div class="bg-white rounded-card border border-slate-100 shadow-card p-6">

        <div class="flex items-start justify-between mb-5">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs text-gray-400 font-mono">#<%= booking.id %></span>
            </div>
            <h1 class="text-xl font-bold text-gray-900">
              <%= booking.eventName %>
            </h1>
            <p class="text-sm text-gray-400 mt-0.5">by <%= booking.organizerName %>
            </p>
          </div>
          <div class="flex flex-col items-end gap-2">
            <% if (booking.bookingStatus==='confirmed' ) { %>
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-blue-500 text-white">Confirmed</span>
              <% } else if (booking.bookingStatus==='pending' ) { %>
                <span class="px-3 py-1 rounded-full text-xs font-semibold bg-amber-500 text-white">Pending</span>
                <% } else { %>
                  <span class="px-3 py-1 rounded-full text-xs font-semibold bg-red-500 text-white">Cancelled</span>
                  <% } %>
                    <% if (booking.paymentStatus==='paid' ) { %>
                      <span class="px-3 py-1 rounded-full text-xs font-semibold bg-emerald-500 text-white">Paid</span>
                      <% } else if (booking.paymentStatus==='unpaid' ) { %>
                        <span class="px-3 py-1 rounded-full text-xs font-semibold bg-rose-500 text-white">Unpaid</span>
                        <% } else { %>
                          <span
                            class="px-3 py-1 rounded-full text-xs font-semibold bg-indigo-500 text-white">Refunded</span>
                          <% } %>
          </div>
        </div>

        <!-- Info Grid -->
        <div class="grid grid-cols-2 gap-3 mb-5">
          <div class="bg-slate-50 rounded-xl p-4">
            <p class="text-[10px] text-gray-400 uppercase tracking-wider font-medium mb-1">Event Date</p>
            <p class="text-sm font-semibold text-gray-900">
              <%= fmtDateRange(booking.startDate, booking.endDate) %>
            </p>
          </div>
          <div class="bg-slate-50 rounded-xl p-4">
            <p class="text-[10px] text-gray-400 uppercase tracking-wider font-medium mb-1">Time</p>
            <p class="text-sm font-semibold text-gray-900">
              <%= fmtTime(booking.startTime) %> – <%= fmtTime(booking.endTime) %>
            </p>
          </div>
          <div class="bg-slate-50 rounded-xl p-4">
            <p class="text-[10px] text-gray-400 uppercase tracking-wider font-medium mb-1">Attendees</p>
            <p class="text-sm font-semibold text-gray-900">
              <%= booking.attendees ? booking.attendees.toLocaleString('id-ID') + ' people' : '—' %>
            </p>
          </div>
          <div class="bg-slate-50 rounded-xl p-4">
            <p class="text-[10px] text-gray-400 uppercase tracking-wider font-medium mb-1">Organizer</p>
            <p class="text-sm font-semibold text-gray-900">
              <%= booking.organizerName %>
            </p>
          </div>
        </div>

        <% if (booking.notes) { %>
          <div class="mb-5 p-4 bg-slate-50 rounded-xl border-l-4 border-blue-200">
            <p class="text-[10px] text-gray-400 uppercase tracking-wider font-medium mb-1">Notes</p>
            <p class="text-sm text-gray-700 leading-relaxed">
              <%= booking.notes %>
            </p>
          </div>
          <% } %>

            <!-- Actions -->
            <div class="flex items-center gap-2.5 pt-4 border-t border-slate-100">
              <a href="/event-bookings/<%= booking.id %>/edit"
                class="inline-flex items-center gap-2 px-4 py-2 bg-amber-400 hover:bg-amber-500 text-white text-sm font-semibold rounded-xl transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Edit Booking
              </a>
              <a href="/event-bookings"
                class="inline-flex items-center gap-2 px-4 py-2 bg-slate-50 hover:bg-slate-100 text-gray-600 text-sm font-medium rounded-xl transition-colors border border-slate-200">
                ← Back
              </a>
              <form action="/event-bookings/<%= booking.id %>/delete" method="POST" class="inline js-delete-form"
                data-delete-title="Hapus booking?" data-delete-message="Booking ini akan dihapus permanen dari sistem."
                data-delete-label="Hapus Booking">
                <button type="submit" aria-label="Delete"
                  class="w-7 h-7 bg-red-500 hover:bg-red-600 text-white rounded-lg flex items-center justify-center transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </form>
            </div>
      </div>
    </div>

    <!-- Right: Venue Info Card -->
    <div>
      <div class="bg-white rounded-card border border-slate-100 shadow-card p-5">
        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Venue Info</h4>

        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-blue-500 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 text-sm">
              <%= booking.venue.name %>
            </p>
            <p class="text-xs text-gray-400">
              <%= booking.venue.location %>
            </p>
          </div>
        </div>

        <div class="space-y-2.5 text-sm border-t border-slate-100 pt-4">
          <div class="flex justify-between">
            <span class="text-xs text-gray-400">Capacity</span>
            <span class="text-xs font-semibold text-gray-700">
              <%= booking.venue.capacity.toLocaleString('id-ID') %> pax
            </span>
          </div>
          <div class="flex justify-between">
            <span class="text-xs text-gray-400">Price / Day</span>
            <span class="text-xs font-semibold text-gray-700">Rp<%=
                Number(booking.venue.pricePerDay).toLocaleString('id-ID') %></span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-xs text-gray-400">Status</span>
            <% if (booking.venue.status==='available' ) { %>
              <span
                class="text-[10px] font-semibold text-white bg-emerald-500 px-2 py-0.5 rounded-full">Available</span>
              <% } else if (booking.venue.status==='maintenance' ) { %>
                <span
                  class="text-[10px] font-semibold text-white bg-amber-500 px-2 py-0.5 rounded-full">Maintenance</span>
                <% } else { %>
                  <span
                    class="text-[10px] font-semibold text-white bg-slate-500 px-2 py-0.5 rounded-full">Inactive</span>
                  <% } %>
          </div>
        </div>

        <% if (booking.venue.facilities) { %>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <p class="text-[10px] text-gray-400 uppercase tracking-wider font-medium mb-1">Facilities</p>
            <p class="text-xs text-gray-600">
              <%= booking.venue.facilities %>
            </p>
          </div>
          <% } %>

            <a href="/venues/<%= booking.venue.id %>"
              class="mt-4 w-full text-center flex items-center justify-center gap-1 text-xs text-white bg-blue-500 hover:bg-blue-600 font-semibold py-2 rounded-xl transition-colors">
              View Venue Details →
            </a>
      </div>
    </div>
  </div>