<% function fmtTime(dt) { const d=new Date(dt); return d.getUTCHours().toString().padStart(2,'0') + ':' +
  d.getUTCMinutes().toString().padStart(2,'0'); } function fmtDate(dt) { return new Date(dt).toLocaleDateString('id-ID',
  { day: '2-digit' , month: 'short' , year: 'numeric' , timeZone: 'UTC' }); } function fmtDateRange(startDt, endDt) {
  const start=fmtDate(startDt); const end=fmtDate(endDt); return start===end ? start : start + ' - ' + end; } function
  pageHref(pageNumber) { const params=[]; if (search) params.push('search=' + encodeURIComponent(search));
    params.push(' page=' + pageNumber);
    return ' /event-bookings?' + params.join('&'); } const pager=typeof pagination !=='undefined' ? pagination : null;
  const pageNumbers=[]; if (pager) { const end=Math.min(pager.totalPages, Math.max(5, pager.currentPage + 2)); const
  start=Math.max(1, Math.min(pager.currentPage - 2, end - 4)); for (let pageNumber=start; pageNumber <=end;
  pageNumber++) { pageNumbers.push(pageNumber); } } %>

  <!-- Header -->
  <div class="flex items-start justify-between mb-6">
    <div>
      <nav class="flex items-center gap-1.5 text-xs text-gray-400 mb-1">
        <span>Home</span>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-gray-700 font-medium">Event Bookings</span>
      </nav>
      <h1 class="text-xl font-bold text-gray-900">Event Bookings</h1>
      <p class="text-xs text-gray-500 mt-0.5">Track event schedules, organizer details, booking status, and payment
        progress.</p>
    </div>
    <a href="/event-bookings/create"
      class="inline-flex items-center gap-2 bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors shadow-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
      </svg>
      Add Booking
    </a>
  </div>

  <!-- Search -->
  <div class="bg-white rounded-2xl border border-slate-100 shadow-card p-4 mb-5">
    <form method="GET" action="/event-bookings">
      <div class="flex gap-3">
        <div class="flex-1 flex items-center gap-2 bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5">
          <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
          </svg>
          <input type="text" name="search" value="<%= search %>"
            placeholder="Search by event name, organizer, venue, or status..."
            class="flex-1 bg-transparent text-sm text-gray-700 placeholder-gray-400 outline-none" />
        </div>
        <button type="submit"
          class="px-4 py-2.5 bg-gray-800 hover:bg-gray-900 text-white text-sm font-semibold rounded-xl transition-colors">
          Search
        </button>
        <% if (search) { %>
          <a href="/event-bookings"
            class="px-4 py-2.5 bg-slate-100 hover:bg-slate-200 text-gray-600 text-sm font-medium rounded-xl transition-colors">
            Clear
          </a>
          <% } %>
      </div>
    </form>
  </div>

  <!-- Table -->
  <div class="bg-white rounded-card border border-slate-100 shadow-card overflow-hidden">
    <div class="px-5 py-3.5 border-b border-slate-50 flex items-center justify-between">
      <p class="text-xs text-gray-400">
        Showing
        <span class="font-semibold text-gray-700">
          <%= pager ? pager.from : bookings.length %>
        </span>-<span class="font-semibold text-gray-700">
          <%= pager ? pager.to : bookings.length %>
        </span>
        of <span class="font-semibold text-gray-700">
          <%= pager ? pager.totalItems : bookings.length %>
        </span>
        booking<%= (pager ? pager.totalItems : bookings.length) !==1 ? 's' : '' %>
          <% if (search) { %> for "<span class="font-medium text-gray-600">
              <%= search %>
            </span>"<% } %>
      </p>
    </div>

    <% if (bookings.length===0) { %>
      <div class="text-center py-16 px-4">
        <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <p class="text-sm font-semibold text-gray-600">
          <% if (search) { %>No bookings found for "<%= search %>"<% } else { %>No bookings yet<% } %>
        </p>
      </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-100">
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Event
                  Name</th>
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Venue
                </th>
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Date &
                  Time</th>
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">
                  Attendees</th>
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Booking
                </th>
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Payment
                </th>
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Actions
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <% bookings.forEach(booking=> { %>
                <tr class="hover:bg-slate-50/60 transition-colors">
                  <td class="px-5 py-3.5">
                    <span class="font-semibold text-gray-900">
                      <%= booking.eventName %>
                    </span>
                    <span class="block text-xs text-gray-400">
                      <%= booking.organizerName %>
                    </span>
                  </td>
                  <td class="px-5 py-3.5 text-gray-500 text-xs">
                    <%= booking.venue.name %>
                  </td>
                  <td class="px-5 py-3.5">
                    <span class="text-gray-700 text-xs font-medium">
                      <%= fmtDateRange(booking.startDate, booking.endDate) %>
                    </span>
                    <span class="block text-[10px] text-gray-400">
                      <%= fmtTime(booking.startTime) %> – <%= fmtTime(booking.endTime) %>
                    </span>
                  </td>
                  <td class="px-5 py-3.5 text-gray-500 text-xs">
                    <%= booking.attendees ? booking.attendees.toLocaleString('id-ID') + ' pax' : '—' %>
                  </td>
                  <td class="px-5 py-3.5">
                    <% if (booking.bookingStatus==='confirmed' ) { %>
                      <span
                        class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-blue-500 text-white">Confirmed</span>
                      <% } else if (booking.bookingStatus==='pending' ) { %>
                        <span
                          class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-amber-500 text-white">Pending</span>
                        <% } else { %>
                          <span
                            class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-red-500 text-white">Cancelled</span>
                          <% } %>
                  </td>
                  <td class="px-5 py-3.5">
                    <% if (booking.paymentStatus==='paid' ) { %>
                      <span
                        class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-500 text-white">Paid</span>
                      <% } else if (booking.paymentStatus==='unpaid' ) { %>
                        <span
                          class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-rose-500 text-white">Unpaid</span>
                        <% } else { %>
                          <span
                            class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-indigo-500 text-white">Refunded</span>
                          <% } %>
                  </td>
                  <td class="px-5 py-3.5">
                    <div class="flex items-center gap-1.5">
                      <a href="/event-bookings/<%= booking.id %>" aria-label="View"
                        class="w-7 h-7 bg-blue-500 hover:bg-blue-600 text-white rounded-lg flex items-center justify-center transition-colors">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                      </a>
                      <a href="/event-bookings/<%= booking.id %>/edit" aria-label="Edit"
                        class="w-7 h-7 bg-amber-500 hover:bg-amber-600 text-white rounded-lg flex items-center justify-center transition-colors">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                      </a>
                      <form action="/event-bookings/<%= booking.id %>/delete" method="POST"
                        class="inline js-delete-form" data-delete-title="Hapus booking?"
                        data-delete-message="Booking ini akan dihapus permanen dari sistem."
                        data-delete-label="Hapus Booking">
                        <button type="submit" aria-label="Delete"
                          class="w-7 h-7 bg-red-500 hover:bg-red-600 text-white rounded-lg flex items-center justify-center transition-colors">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                          </svg>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>

        <% if (pager && pager.totalPages> 1) { %>
          <div class="px-5 py-4 border-t border-slate-100 flex items-center justify-between gap-3">
            <p class="text-xs text-gray-400">
              Page <span class="font-semibold text-gray-700">
                <%= pager.currentPage %>
              </span> of <span class="font-semibold text-gray-700">
                <%= pager.totalPages %>
              </span>
            </p>

            <div class="flex items-center gap-1.5">
              <% if (pager.hasPrevious) { %>
                <a href="<%= pageHref(pager.currentPage - 1) %>"
                  class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-100 hover:bg-slate-200 text-gray-700 transition-colors">
                  Previous
                </a>
                <% } else { %>
                  <span class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-100 text-gray-400">Previous</span>
                  <% } %>

                    <% pageNumbers.forEach(function(pageNumber) { %>
                      <% if (pageNumber===pager.currentPage) { %>
                        <span
                          class="w-8 h-8 rounded-lg text-xs font-semibold bg-blue-500 text-white flex items-center justify-center">
                          <%= pageNumber %>
                        </span>
                        <% } else { %>
                          <a href="<%= pageHref(pageNumber) %>"
                            class="w-8 h-8 rounded-lg text-xs font-semibold bg-slate-100 hover:bg-slate-200 text-gray-700 flex items-center justify-center transition-colors">
                            <%= pageNumber %>
                          </a>
                          <% } %>
                            <% }) %>

                              <% if (pager.hasNext) { %>
                                <a href="<%= pageHref(pager.currentPage + 1) %>"
                                  class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-blue-500 hover:bg-blue-600 text-white transition-colors">
                                  Next
                                </a>
                                <% } else { %>
                                  <span
                                    class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-100 text-gray-400">Next</span>
                                  <% } %>
            </div>
          </div>
          <% } %>
            <% } %>
  </div>