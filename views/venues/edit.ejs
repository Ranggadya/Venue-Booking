<%
  const form = typeof oldInput !== 'undefined' && oldInput ? oldInput : {};
  const fieldValue = function (name, fallback) {
    return form[name] !== undefined && form[name] !== null ? form[name] : fallback;
  };
  const selectedStatus = fieldValue('status', venue.status);
%>

<!-- Breadcrumb -->
<nav class="flex items-center gap-1.5 text-xs text-gray-400 mb-5">
  <a href="/venues" class="hover:text-blue-500">Venues</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <a href="/venues/<%= venue.id %>" class="hover:text-blue-500"><%= venue.name %></a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-700 font-medium">Edit</span>
</nav>

<div class="max-w-2xl">
  <div class="bg-white rounded-card border border-slate-100 shadow-card p-6">
    <div class="mb-6">
      <h1 class="text-lg font-bold text-gray-900">Edit Venue</h1>
      <p class="text-xs text-gray-400 mt-0.5">Update venue information below.</p>
    </div>

    <form action="/venues/<%= venue.id %>/update" method="POST" class="space-y-4">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Venue Name <span class="text-red-400">*</span></label>
        <input type="text" name="name" required maxlength="150" value="<%= fieldValue('name', venue.name) %>"
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Location <span class="text-red-400">*</span></label>
        <input type="text" name="location" required maxlength="255" value="<%= fieldValue('location', venue.location) %>"
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 transition-colors" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Capacity <span class="text-red-400">*</span></label>
          <input type="number" name="capacity" required min="1" value="<%= fieldValue('capacity', venue.capacity) %>"
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Price per Day (Rp) <span class="text-red-400">*</span></label>
          <input type="number" name="price_per_day" required min="0" value="<%= fieldValue('price_per_day', Number(venue.pricePerDay)) %>"
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 transition-colors" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Status <span class="text-red-400">*</span></label>
        <select name="status" required
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 transition-colors">
          <option value="available" <%= selectedStatus === 'available' ? 'selected' : '' %>>Available</option>
          <option value="maintenance" <%= selectedStatus === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
          <option value="inactive" <%= selectedStatus === 'inactive' ? 'selected' : '' %>>Inactive</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Facilities <span class="text-gray-400 text-xs font-normal">(optional)</span></label>
        <textarea name="facilities" rows="2"
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 resize-none transition-colors"><%= fieldValue('facilities', venue.facilities ?? '') %></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Description <span class="text-gray-400 text-xs font-normal">(optional)</span></label>
        <textarea name="description" rows="3"
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 resize-none transition-colors"><%= fieldValue('description', venue.description ?? '') %></textarea>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit"
          class="px-5 py-2.5 bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold rounded-xl transition-colors shadow-sm">
          Save Changes
        </button>
        <a href="/venues/<%= venue.id %>"
          class="px-5 py-2.5 bg-slate-50 hover:bg-slate-100 text-gray-600 text-sm font-medium rounded-xl transition-colors border border-slate-200">
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>
