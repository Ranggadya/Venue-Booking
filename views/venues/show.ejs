<%
  function fmtTime(dt) {
    const d = new Date(dt);
    return d.getUTCHours().toString().padStart(2,'0') + ':' + d.getUTCMinutes().toString().padStart(2,'0');
  }
  function fmtDate(dt) {
    return new Date(dt).toLocaleDateString('id-ID', {
      day: '2-digit', month: 'short', year: 'numeric', timeZone: 'UTC'
    });
  }
%>

<!-- Breadcrumb -->
<nav class="flex items-center gap-1.5 text-xs text-gray-400 mb-5">
  <a href="/venues" class="hover:text-blue-500 transition-colors">Venues</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-700 font-medium"><%= venue.name %></span>
</nav>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

  <!-- Main Content -->
  <div class="lg:col-span-2 space-y-5">

    <!-- Venue Header Card -->
    <div class="bg-white rounded-card border border-slate-100 shadow-card p-6">
      <div class="flex items-start justify-between mb-5">
        <div>
          <h1 class="text-xl font-bold text-gray-900"><%= venue.name %></h1>
          <p class="text-sm text-gray-400 mt-0.5 flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <%= venue.location %>
          </p>
        </div>
        <% if (venue.status === 'available') { %>
          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-emerald-500 text-white">
            <span class="w-1.5 h-1.5 rounded-full bg-white inline-block"></span>Available
          </span>
        <% } else if (venue.status === 'maintenance') { %>
          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-amber-500 text-white">
            <span class="w-1.5 h-1.5 rounded-full bg-white inline-block"></span>Maintenance
          </span>
        <% } else { %>
          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-slate-500 text-white">
            <span class="w-1.5 h-1.5 rounded-full bg-white inline-block"></span>Inactive
          </span>
        <% } %>
      </div>

      <!-- Info Grid -->
      <div class="grid grid-cols-2 gap-3 mb-5">
        <div class="bg-slate-50 rounded-xl p-4">
          <p class="text-[10px] text-gray-400 font-medium uppercase tracking-wider mb-1">Capacity</p>
          <p class="text-2xl font-bold text-gray-900"><%= venue.capacity.toLocaleString('id-ID') %></p>
          <p class="text-xs text-gray-400">people max</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-4">
          <p class="text-[10px] text-gray-400 font-medium uppercase tracking-wider mb-1">Price / Day</p>
          <p class="text-2xl font-bold text-gray-900">Rp<%= Number(venue.pricePerDay).toLocaleString('id-ID') %></p>
          <p class="text-xs text-gray-400">per day</p>
        </div>
      </div>

      <% if (venue.facilities) { %>
        <div class="mb-4 p-3.5 bg-slate-50 rounded-xl">
          <p class="text-[10px] text-gray-400 font-medium uppercase tracking-wider mb-1">Facilities</p>
          <p class="text-sm text-gray-700"><%= venue.facilities %></p>
        </div>
      <% } %>

      <% if (venue.description) { %>
        <div class="mb-4 p-3.5 bg-slate-50 rounded-xl">
          <p class="text-[10px] text-gray-400 font-medium uppercase tracking-wider mb-1">Description</p>
          <p class="text-sm text-gray-700 leading-relaxed"><%= venue.description %></p>
        </div>
      <% } %>

      <!-- Actions -->
      <div class="flex items-center gap-2.5 pt-4 border-t border-slate-100">
        <a href="/venues/<%= venue.id %>/edit"
          class="inline-flex items-center gap-2 px-4 py-2 bg-amber-400 hover:bg-amber-500 text-white text-sm font-semibold rounded-xl transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Edit Venue
        </a>
        <a href="/event-bookings/create"
          class="inline-flex items-center gap-2 px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold rounded-xl transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add Booking
        </a>
        <form action="/venues/<%= venue.id %>/delete" method="POST" class="ml-auto"
              onsubmit="return confirm('Delete this venue? Ensure there are no active bookings.')">
          <button type="submit"
            class="inline-flex items-center gap-2 px-4 py-2 bg-red-500 hover:bg-red-600 text-white text-sm font-semibold rounded-xl transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            Delete
          </button>
        </form>
      </div>
    </div>

    <!-- Related Bookings Table -->
    <div class="bg-white rounded-card border border-slate-100 shadow-card overflow-hidden">
      <div class="px-5 py-4 border-b border-slate-50 flex items-center justify-between">
        <h3 class="text-sm font-bold text-gray-900">Booking History</h3>
        <span class="text-xs text-gray-400"><%= venue.bookings.length %> booking<%= venue.bookings.length !== 1 ? 's' : '' %></span>
      </div>

      <% if (venue.bookings.length === 0) { %>
        <div class="text-center py-10 px-4">
          <p class="text-sm text-gray-400">No bookings for this venue yet</p>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-100">
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Event</th>
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Date & Time</th>
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Status</th>
                <th class="px-5 py-3 text-left text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <% venue.bookings.forEach(booking => { %>
                <tr class="hover:bg-slate-50/60 transition-colors">
                  <td class="px-5 py-3.5">
                    <span class="font-semibold text-gray-900 text-sm"><%= booking.eventName %></span>
                    <span class="block text-xs text-gray-400"><%= booking.organizerName %></span>
                  </td>
                  <td class="px-5 py-3.5">
                    <span class="text-gray-700 text-xs font-medium"><%= fmtDate(booking.eventDate) %></span>
                    <span class="block text-[10px] text-gray-400"><%= fmtTime(booking.startTime) %> – <%= fmtTime(booking.endTime) %></span>
                  </td>
                  <td class="px-5 py-3.5">
                    <% if (booking.bookingStatus === 'confirmed') { %>
                      <span class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-blue-500 text-white">Confirmed</span>
                    <% } else if (booking.bookingStatus === 'pending') { %>
                      <span class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-amber-500 text-white">Pending</span>
                    <% } else { %>
                      <span class="inline-flex px-2.5 py-0.5 rounded-full text-[10px] font-semibold bg-red-500 text-white">Cancelled</span>
                    <% } %>
                  </td>
                  <td class="px-5 py-3.5">
                    <a href="/event-bookings/<%= booking.id %>"
                      class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold bg-blue-500 hover:bg-blue-600 text-white transition-colors">View Details →</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Right Sidebar: Quick Stats -->
  <div class="space-y-4">
    <div class="bg-white rounded-card border border-slate-100 shadow-card p-5">
      <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Quick Stats</h4>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-xs text-gray-500">Total bookings</span>
          <span class="text-sm font-bold text-gray-900"><%= venue.bookings.length %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-xs text-gray-500">Confirmed</span>
          <span class="text-sm font-bold text-blue-600">
            <%= venue.bookings.filter(b => b.bookingStatus === 'confirmed').length %>
          </span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-xs text-gray-500">Pending</span>
          <span class="text-sm font-bold text-amber-600">
            <%= venue.bookings.filter(b => b.bookingStatus === 'pending').length %>
          </span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-xs text-gray-500">Cancelled</span>
          <span class="text-sm font-bold text-red-500">
            <%= venue.bookings.filter(b => b.bookingStatus === 'cancelled').length %>
          </span>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-card border border-slate-100 shadow-card p-5">
      <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Quick Actions</h4>
      <div class="space-y-2">
        <a href="/event-bookings/create"
          class="w-full flex items-center gap-2 px-3 py-2.5 bg-blue-500 hover:bg-blue-600 text-white text-xs font-semibold rounded-xl transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          New Booking for This Venue
        </a>
        <a href="/venues"
          class="w-full flex items-center gap-2 px-3 py-2.5 bg-slate-50 hover:bg-slate-100 text-gray-600 text-xs font-medium rounded-xl transition-colors border border-slate-200">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Back to Venues
        </a>
      </div>
    </div>
  </div>

</div>
