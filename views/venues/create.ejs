<%
  const form = typeof oldInput !== 'undefined' && oldInput ? oldInput : {};
  const fieldValue = function (name, fallback) {
    return form[name] !== undefined && form[name] !== null ? form[name] : fallback;
  };
  const oldPrice = fieldValue('price_per_day', '');
  const oldPriceDisplay = oldPrice ? 'Rp ' + Number(oldPrice).toLocaleString('id-ID') : '';
%>

<!-- Breadcrumb -->
<nav class="flex items-center gap-1.5 text-xs text-gray-400 mb-5">
  <a href="/venues" class="hover:text-blue-500 transition-colors">Venues</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-700 font-medium">Add Venue</span>
</nav>

<div class="max-w-2xl">
  <div class="bg-white rounded-card border border-slate-100 shadow-card p-6">
    <div class="mb-6">
      <h1 class="text-lg font-bold text-gray-900">Add New Venue</h1>
      <p class="text-xs text-gray-400 mt-0.5">Fill in the venue details below. Fields marked with * are required.</p>
    </div>

    <form action="/venues" method="POST" class="space-y-4">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">
          Venue Name <span class="text-red-400">*</span>
        </label>
        <input type="text" name="name" required maxlength="150" value="<%= fieldValue('name', '') %>"
          placeholder="e.g. Main Auditorium"
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 placeholder-gray-400 transition-colors" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">
          Location <span class="text-red-400">*</span>
        </label>
        <input type="text" name="location" required maxlength="255" value="<%= fieldValue('location', '') %>"
          placeholder="e.g. Building A, 2nd Floor"
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 placeholder-gray-400 transition-colors" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">
            Capacity (people) <span class="text-red-400">*</span>
          </label>
          <input type="number" name="capacity" required min="1" value="<%= fieldValue('capacity', '') %>"
            placeholder="e.g. 300"
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 placeholder-gray-400 transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">
            Price per Day (Rp) <span class="text-red-400">*</span>
          </label>
          <input type="hidden" name="price_per_day" id="pricePerDayValue" value="<%= oldPrice %>" />
          <input type="text" id="pricePerDayDisplay" required inputmode="numeric" value="<%= oldPriceDisplay %>"
            placeholder="e.g. Rp 5.000.000"
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 placeholder-gray-400 transition-colors" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">
          Status <span class="text-red-400">*</span>
        </label>
        <select name="status" required
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 transition-colors">
          <option value="available" <%= fieldValue('status', 'available') === 'available' ? 'selected' : '' %>>Available</option>
          <option value="maintenance" <%= fieldValue('status', 'available') === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
          <option value="inactive" <%= fieldValue('status', 'available') === 'inactive' ? 'selected' : '' %>>Inactive</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">
          Facilities <span class="text-gray-400 text-xs font-normal">(optional)</span>
        </label>
        <textarea name="facilities" rows="2"
          placeholder="e.g. AC, Projector, Microphone, Sound System"
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 placeholder-gray-400 resize-none transition-colors"><%= fieldValue('facilities', '') %></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">
          Description <span class="text-gray-400 text-xs font-normal">(optional)</span>
        </label>
        <textarea name="description" rows="3"
          placeholder="Additional description about this venue..."
          class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent bg-slate-50 placeholder-gray-400 resize-none transition-colors"><%= fieldValue('description', '') %></textarea>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit"
          class="px-5 py-2.5 bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold rounded-xl transition-colors shadow-sm">
          Save Venue
        </button>
        <a href="/venues"
          class="px-5 py-2.5 bg-slate-50 hover:bg-slate-100 text-gray-600 text-sm font-medium rounded-xl transition-colors border border-slate-200">
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>

<script>
(function () {
  var displayInput = document.getElementById('pricePerDayDisplay');
  var valueInput = document.getElementById('pricePerDayValue');
  if (!displayInput || !valueInput) return;

  function digitsOnly(value) {
    return value.replace(/\D/g, '');
  }

  function formatRupiah(value) {
    var digits = digitsOnly(value);
    if (!digits) return '';

    return 'Rp ' + Number(digits).toLocaleString('id-ID');
  }

  function syncPrice() {
    var digits = digitsOnly(displayInput.value);
    valueInput.value = digits;
    displayInput.value = formatRupiah(digits);
  }

  displayInput.addEventListener('input', syncPrice);
  displayInput.closest('form').addEventListener('submit', syncPrice);
})();
</script>
