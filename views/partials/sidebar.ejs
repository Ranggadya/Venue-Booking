<%
  // currentPath diinject otomatis dari middleware res.locals
  // Fungsi isActive: return class 'active' jika path cocok
  const _path = typeof currentPath !== 'undefined' ? currentPath : '';
  function isActive(prefix) {
    return _path === prefix || _path.startsWith(prefix + '/') ? true : false;
  }
%>

<aside style="width:260px;min-width:260px;" class="fixed top-0 left-0 h-screen bg-white border-r border-slate-100 flex flex-col z-30 shadow-card">

  <!-- Brand -->
  <div class="px-5 py-4 border-b border-slate-100">
    <div>
      <h1 class="text-sm font-bold text-gray-900 leading-tight">VenueControl</h1>
      <p class="text-xs text-gray-400 leading-tight">Booking Management</p>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
    <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-widest px-3 mb-2">Menu</p>

    <!-- Dashboard -->
    <a href="/dashboard"
       class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all
              <%= isActive('/dashboard') ? 'bg-blue-500 text-white shadow-sm' : 'text-gray-500 hover:bg-blue-50 hover:text-blue-600' %>">
      <svg class="w-4.5 h-4.5 flex-shrink-0" style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      Dashboard
    </a>

    <!-- Venues -->
    <a href="/venues"
       class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all
              <%= isActive('/venues') ? 'bg-blue-500 text-white shadow-sm' : 'text-gray-500 hover:bg-blue-50 hover:text-blue-600' %>">
      <svg class="w-4.5 h-4.5 flex-shrink-0" style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
      </svg>
      Venues
    </a>

    <!-- Event Bookings -->
    <a href="/event-bookings"
       class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all
              <%= isActive('/event-bookings') ? 'bg-blue-500 text-white shadow-sm' : 'text-gray-500 hover:bg-blue-50 hover:text-blue-600' %>">
      <svg class="w-4.5 h-4.5 flex-shrink-0" style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      Event Bookings
    </a>

  </nav>

  <!-- User & Logout -->
  <div class="px-3 py-3 border-t border-slate-100">
    <div class="flex items-center gap-2.5 px-3 py-2 mb-1">
      <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
        <%= (typeof user !== 'undefined' && user && user.name) ? user.name.charAt(0).toUpperCase() : 'A' %>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-sm font-semibold text-gray-800 truncate leading-tight">
          <%= (typeof user !== 'undefined' && user) ? user.name : 'Admin' %>
        </p>
        <p class="text-xs text-gray-400 truncate leading-tight">
          <%= (typeof user !== 'undefined' && user) ? user.email : 'admin@venue.com' %>
        </p>
      </div>
    </div>
    <form action="/logout" method="POST">
      <button type="submit"
        class="w-full flex items-center gap-2.5 px-3 py-2 text-sm text-red-500 hover:bg-red-50 hover:text-red-600 rounded-xl transition-colors font-medium">
        <svg style="width:16px;height:16px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        Logout
      </button>
    </form>
  </div>

</aside>
