<header class="bg-white border-b border-slate-100 px-6 h-14 flex items-center gap-4 sticky top-0 z-20 shadow-card">

  <!-- Page Title -->
  <h2 class="text-sm font-bold text-gray-900 flex-shrink-0">
    <%= typeof title !== 'undefined' ? title : 'Dashboard' %>
  </h2>

  <!-- Right Actions -->
  <div class="flex items-center gap-2 ml-auto">
    <!-- Admin Profile -->
    <div class="flex items-center gap-2">
      <div class="w-7 h-7 bg-blue-500 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
        <%= (typeof user !== 'undefined' && user && user.name) ? user.name.charAt(0).toUpperCase() : 'A' %>
      </div>
      <div class="hidden sm:block">
        <p class="text-xs font-semibold text-gray-800 leading-tight">
          <%= (typeof user !== 'undefined' && user) ? user.name : 'Admin' %>
        </p>
        <p class="text-[10px] text-gray-400 leading-tight">Super Admin</p>
      </div>
      <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>

</header>
