<div id="confirmModal" class="fixed inset-0 z-50 hidden items-center justify-center px-4" aria-hidden="true">
  <div class="absolute inset-0 bg-slate-900/45 backdrop-blur-sm" data-confirm-cancel></div>
  <div class="relative w-full max-w-md rounded-2xl bg-white p-6 shadow-2xl">
    <div class="mb-4 flex items-start gap-3">
      <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-xl bg-red-50">
        <svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
      </div>
      <div>
        <h2 id="confirmModalTitle" class="text-base font-bold text-gray-900">Konfirmasi aksi</h2>
        <p id="confirmModalMessage" class="mt-1 text-sm leading-relaxed text-gray-500">Apakah kamu yakin ingin melanjutkan?</p>
      </div>
    </div>

    <div class="flex justify-end gap-2 pt-2">
      <button type="button" data-confirm-cancel
        class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-gray-600 transition-colors hover:bg-slate-50">
        Batal
      </button>
      <button type="button" id="confirmModalSubmit"
        class="rounded-xl bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-red-700">
        Hapus
      </button>
    </div>
  </div>
</div>

<script>
(function () {
  var modal = document.getElementById('confirmModal');
  var title = document.getElementById('confirmModalTitle');
  var message = document.getElementById('confirmModalMessage');
  var submitButton = document.getElementById('confirmModalSubmit');
  if (!modal || !title || !message || !submitButton) return;

  var pendingForm = null;
  var nativeSubmit = HTMLFormElement.prototype.submit;

  function closeModal() {
    pendingForm = null;
    submitButton.disabled = false;
    submitButton.classList.remove('opacity-70', 'cursor-not-allowed');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    modal.setAttribute('aria-hidden', 'true');
  }

  function openModal(sourceForm) {
    pendingForm = sourceForm;
    title.textContent = sourceForm.dataset.confirmTitle || 'Konfirmasi aksi';
    message.textContent = sourceForm.dataset.confirmMessage || 'Apakah kamu yakin ingin melanjutkan?';
    submitButton.textContent = sourceForm.dataset.confirmLabel || 'Lanjutkan';
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    modal.setAttribute('aria-hidden', 'false');
    submitButton.focus();
  }

  document.addEventListener('click', function (event) {
    if (!(event.target instanceof Element)) return;

    var trigger = event.target.closest('form[data-confirm] button[type="submit"]');
    if (!trigger) return;

    var sourceForm = trigger.closest('form[data-confirm]');
    if (!sourceForm) return;

    event.preventDefault();
    openModal(sourceForm);
  });

  document.addEventListener('submit', function (event) {
    var sourceForm = event.target;
    if (!(sourceForm instanceof HTMLFormElement) || !sourceForm.dataset.confirm) return;

    event.preventDefault();
    openModal(sourceForm);
  });

  submitButton.addEventListener('click', function () {
    if (!pendingForm) return;

    var form = pendingForm;
    submitButton.disabled = true;
    submitButton.classList.add('opacity-70', 'cursor-not-allowed');
    nativeSubmit.call(form);
  });

  document.querySelectorAll('[data-confirm-cancel]').forEach(function (button) {
    button.addEventListener('click', closeModal);
  });

  document.addEventListener('keydown', function (event) {
    if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });
})();
</script>
