<% if (typeof messages !== 'undefined' && messages) { %>

  <% if (messages.success && messages.success.length > 0) { %>
    <div class="js-flash-message mb-5 flex items-start gap-3 p-4 bg-green-600 text-white rounded-2xl shadow-sm" data-dismiss-delay="3500">
      <div class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0 mt-0.5">
        <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
      </div>
      <p class="text-sm text-white font-medium"><%= messages.success[0] %></p>
    </div>
  <% } %>

  <% if (messages.error && messages.error.length > 0) { %>
    <div class="js-flash-message mb-5 flex items-start gap-3 p-4 bg-red-600 text-white rounded-2xl shadow-sm" data-dismiss-delay="4500">
      <div class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0 mt-0.5">
        <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </div>
      <p class="text-sm text-white font-medium"><%= messages.error[0] %></p>
    </div>
  <% } %>

  <% if (messages.info && messages.info.length > 0) { %>
    <div class="js-flash-message mb-5 flex items-start gap-3 p-4 bg-blue-600 text-white rounded-2xl shadow-sm" data-dismiss-delay="3500">
      <div class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0 mt-0.5">
        <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
      </div>
      <p class="text-sm text-white font-medium"><%= messages.info[0] %></p>
    </div>
  <% } %>

  <script>
    (function () {
      var messages = document.querySelectorAll('.js-flash-message');
      messages.forEach(function (message) {
        var delay = Number(message.dataset.dismissDelay || 3500);

        window.setTimeout(function () {
          message.style.transition = 'opacity 300ms ease, transform 300ms ease, max-height 300ms ease, margin 300ms ease, padding 300ms ease';
          message.style.opacity = '0';
          message.style.transform = 'translateY(-8px)';
          message.style.maxHeight = message.offsetHeight + 'px';

          window.setTimeout(function () {
            message.style.maxHeight = '0';
            message.style.marginTop = '0';
            message.style.marginBottom = '0';
            message.style.paddingTop = '0';
            message.style.paddingBottom = '0';
          }, 20);

          window.setTimeout(function () {
            message.remove();
          }, 340);
        }, delay);
      });
    })();
  </script>

<% } %>
