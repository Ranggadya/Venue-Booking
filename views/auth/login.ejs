<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — VenueControl</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css" />
</head>
<body class="min-h-screen font-sans" style="background:#F4F7FB;">

  <div class="min-h-screen flex">

    <!-- Left Panel — Visual (desktop only) -->
    <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-blue-600 to-indigo-700 flex-col items-center justify-center p-12 relative overflow-hidden">
      <!-- Decorative circles -->
      <div class="absolute top-0 right-0 w-64 h-64 rounded-full opacity-10" style="background:rgba(255,255,255,.3);transform:translate(30%,-30%);"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 rounded-full opacity-10" style="background:rgba(255,255,255,.3);transform:translate(-30%,30%);"></div>

      <div class="relative z-10 text-center">
        <div class="w-16 h-16 bg-white bg-opacity-20 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-white mb-3">VenueControl</h1>
        <p class="text-blue-200 text-base leading-relaxed max-w-xs">
          Manage venue data, event schedules, booking status, and payment progress in one place.
        </p>

        <div class="mt-10 grid grid-cols-3 gap-4 text-center">
          <div class="bg-white bg-opacity-10 rounded-2xl p-4">
            <p class="text-2xl font-bold text-white">5</p>
            <p class="text-xs text-blue-200 mt-1">Venues</p>
          </div>
          <div class="bg-white bg-opacity-10 rounded-2xl p-4">
            <p class="text-2xl font-bold text-white">15</p>
            <p class="text-xs text-blue-200 mt-1">Bookings</p>
          </div>
          <div class="bg-white bg-opacity-10 rounded-2xl p-4">
            <p class="text-2xl font-bold text-white">9</p>
            <p class="text-xs text-blue-200 mt-1">Confirmed</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Panel — Form -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-6">
      <div class="w-full max-w-md">

        <!-- Logo mobile -->
        <div class="lg:hidden text-center mb-8">
          <div class="w-12 h-12 bg-blue-500 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5" />
            </svg>
          </div>
          <h1 class="text-xl font-bold text-gray-900">VenueControl</h1>
        </div>

        <div class="bg-white rounded-[20px] border border-slate-100 shadow-soft p-8">
          <div class="mb-7">
            <h2 class="text-2xl font-bold text-gray-900">Welcome back</h2>
            <p class="text-sm text-gray-500 mt-1">Sign in to manage venues, bookings, and event schedules.</p>
          </div>

          <!-- Flash Error -->
          <% if (typeof messages !== 'undefined' && messages && messages.error && messages.error.length > 0) { %>
            <div class="mb-5 flex items-start gap-3 p-3.5 bg-red-600 text-white rounded-xl shadow-sm">
              <svg class="w-4 h-4 text-white flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
              <p class="text-sm text-white"><%= messages.error[0] %></p>
            </div>
          <% } %>

          <form action="/login" method="POST" class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
              <input type="email" name="email" required autocomplete="email"
                placeholder="admin@smartvenue.id"
                class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-slate-50 placeholder-gray-400 transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Password</label>
              <input type="password" name="password" required autocomplete="current-password"
                placeholder="••••••••"
                class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-slate-50 placeholder-gray-400 transition-colors" />
            </div>
            <button type="submit"
              class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2.5 px-4 rounded-xl text-sm transition-colors shadow-sm mt-2">
              Sign In to Dashboard
            </button>
          </form>

          <div class="mt-5 pt-5 border-t border-slate-100 text-center">
            <p class="text-xs text-gray-400">Demo: <span class="font-mono text-gray-600">admin@smartvenue.id</span> / <span class="font-mono text-gray-600">Admin@1234</span></p>
          </div>
        </div>

        <p class="text-center text-xs text-gray-400 mt-5">
          &copy; <%= new Date().getFullYear() %> VenueControl — Smart Venue & Event Booking Management
        </p>
      </div>
    </div>

  </div>
</body>
</html>
